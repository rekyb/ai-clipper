# --- Backend (FastAPI) ---
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=ai_clipper

MEDIA_DIR=./media
MODELS_DIR=./models

# Model file paths (relative to MODELS_DIR)
WHISPER_MEDIUM_DIR=whisper-medium
WHISPER_LARGE_V3_DIR=whisper-large-v3
LLAMA_MODEL_FILE=llama-3.1-8b-q5/llama-3.1-8b-instruct-q5_k_m.gguf

# Inference
CUDA_VISIBLE_DEVICES=0
WHISPER_COMPUTE_TYPE=float16
LLAMA_N_GPU_LAYERS=-1

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Video import limits
MAX_FILE_SIZE_BYTES=5368709120
MAX_DURATION_SECONDS=14400
SUPPORTED_CONTAINERS=mp4,mkv,mov,avi,webm
ALLOWED_URL_HOSTS=youtube.com,youtu.be,www.youtube.com,m.youtube.com

# Transcription pipeline (Phase 2B)
WHISPER_VRAM_BUDGET_MB=2200
VRAM_SAFETY_MARGIN_MB=300
SKIP_VRAM_GUARD=false
TRANSCRIPTION_POLL_INTERVAL_SEC=2.0
TRANSCRIPTION_TIMEOUT_MULTIPLIER=4.0
TRANSCRIPTION_PROGRESS_THROTTLE_SEC=1.0

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
