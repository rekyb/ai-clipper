# --- Backend (FastAPI) ---
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=ai_clipper

MEDIA_DIR=./media
MODELS_DIR=./models

# Model file paths (relative to MODELS_DIR)
WHISPER_MEDIUM_DIR=whisper-medium
WHISPER_LARGE_V3_DIR=whisper-large-v3
LLAMA_MODEL_FILE=llama-3.1-8b-q5/llama-3.1-8b-instruct-q5_k_m.gguf

# Inference
CUDA_VISIBLE_DEVICES=0
WHISPER_COMPUTE_TYPE=float16
LLAMA_N_GPU_LAYERS=-1

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
